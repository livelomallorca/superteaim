# superteaim — Required environment variables
# Copy to .env and fill in real values before starting

# Database
POSTGRES_DB=superteaim
POSTGRES_USER=superteaim
POSTGRES_PASSWORD=          # REQUIRED — generate with: openssl rand -hex 24

# Redis
REDIS_PASSWORD=             # REQUIRED — generate with: openssl rand -hex 24

# ChromaDB
CHROMA_TOKEN=               # REQUIRED — generate with: openssl rand -hex 24

# LiteLLM
LITELLM_MASTER_KEY=         # REQUIRED — generate with: openssl rand -hex 24

# Boss Agent API
BOSS_API_KEY=               # REQUIRED — generate with: openssl rand -hex 24

# Monitoring (only needed with monitoring compose)
GRAFANA_ADMIN_PASSWORD=     # REQUIRED if using monitoring stack

# Optional — uncomment to override defaults
# POSTGRES_PORT=5432
# REDIS_PORT=6379
# CHROMA_PORT=8000
# LITELLM_PORT=4000
# BOSS_PORT=8080
# WEBUI_PORT=3001
# OPENBAO_PORT=8200
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000
