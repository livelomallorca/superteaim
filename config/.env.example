# ============================================================
# superteaim — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp config/.env.example .env
#
# All values have sensible defaults for local development.
# Only INFERENCE_URL is required — point it to your model server.
# ============================================================

# ── Inference ────────────────────────────────────────────────
# Where your models run. This is the ONLY required setting.
# Examples:
#   Local Ollama (Mac/Linux):  http://host.docker.internal:11434
#   Local Ollama (Linux only): http://172.17.0.1:11434
#   Remote vLLM server:        http://192.168.1.100:8000
#   Cloud fallback:             https://api.openai.com/v1
INFERENCE_URL=http://host.docker.internal:11434

# Embedding model endpoint (can be same as INFERENCE_URL)
EMBEDDING_URL=http://host.docker.internal:11434
EMBEDDING_MODEL=nomic-embed-text

# ── Database ─────────────────────────────────────────────────
POSTGRES_DB=superteaim
POSTGRES_USER=superteaim
POSTGRES_PASSWORD=             # REQUIRED — generate with: openssl rand -hex 16
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=             # REQUIRED — generate with: openssl rand -hex 16
REDIS_PORT=6379

# ── ChromaDB ─────────────────────────────────────────────────
CHROMA_TOKEN=               # REQUIRED — generate with: openssl rand -hex 16
CHROMA_PORT=8000

# ── LiteLLM (Model Router) ──────────────────────────────────
LITELLM_PORT=4000
LITELLM_MASTER_KEY=         # REQUIRED — generate with: openssl rand -hex 16 (prefix with sk-)

# Default model names (must match litellm_config.yaml model_name entries)
FAST_MODEL=fast
REASONING_MODEL=reasoning
CODER_MODEL=coder

# ── Boss Agent ───────────────────────────────────────────────
BOSS_API_KEY=               # REQUIRED — generate with: openssl rand -hex 16
BOSS_MODEL=fast
BOSS_PORT=8080

# ── Worker Agents ────────────────────────────────────────────
# Each worker is configured via environment in docker-compose.agents.yml.
# These are global defaults:
DEFAULT_TASK_TIMEOUT=300

# ── Intelligence Toggles ─────────────────────────────────────
# Enable reflection: worker checks its own output before returning
ENABLE_REFLECTION=true
MAX_REASONING_STEPS=2

# Enable memory: worker queries past similar tasks before processing
ENABLE_MEMORY=true
MEMORY_LOOKBACK_HOURS=72

# ── Monitoring (optional, --profile monitoring) ──────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=     # REQUIRED if using monitoring — generate with: openssl rand -hex 16
PROMETHEUS_PORT=9090

# ── OpenBao / Secrets (optional, --profile full) ─────────────
OPENBAO_PORT=8200

# ── Open WebUI (optional, --profile full) ────────────────────
WEBUI_PORT=3001

# ── Caddy / Reverse Proxy (optional, --profile full) ─────────
# Your domain for TLS. Leave empty for localhost.
DOMAIN=

# ── Alerting (optional) ──────────────────────────────────────
# Telegram bot for watchdog + approval gate alerts (leave empty to disable)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Approval Gates (v0.3) ─────────────────────────────────────
# Comma-separated keywords that classify a task as VAULT zone.
# VAULT tasks from API requests are held for human approval before dispatch.
VAULT_KEYWORDS=password,credential,secret,private,confidential,personal,financial

# Public URL of the boss-agent (used in approval notification messages).
# Set to your LAN IP or domain so Telegram messages contain clickable links.
BOSS_EXTERNAL_URL=http://localhost:8080

# ── Backup ───────────────────────────────────────────────────
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30

# ── Knowledge Indexing ───────────────────────────────────────
# Folders to index into ChromaDB (comma-separated)
KNOWLEDGE_DIRS=/library
KNOWLEDGE_ZONE=library

# ── Cloud API Fallback (uncomment to enable) ─────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# DEEPSEEK_API_KEY=sk-...
